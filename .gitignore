# --- soulbrew workspace .gitignore ---
# This top-level folder is a workspace / notes repo. The folders under
# github.com/ are INDEPENDENT git repos (their own .git + remotes), so they
# must not be embedded here. Only the top-level docs are tracked.

# Cloned repos (GHQ-style root) — each is its own git repo with its own remote
/github.com/

# Dependencies & build output (in case any land at the top level)
node_modules/
dist/
build/
.cache/
*.tsbuildinfo

# Logs & databases
*.log
*.sqlite
*.sqlite3
*.db

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# Env / secrets
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Mission Control extension build artifacts (source is tracked; out/ is generated)
/extension/out/

todo.md

# Oracle / maw runtime artifacts (inbox, team mailbox/manifest, spawn prompts) — machine-local + transient; oracle จริงอยู่ ~/.oracle
ψ/agents/

# maw team worktrees (embedded git repos) + local oracle vault
agents/
ψ/

# orchestrator resume marker (machine-local, changes every run)
.orches-meta.json
